{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "1578058169925463227"
    }
  },
  "parameters": {
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the Log Analytics workspace that receives StorageBlobLogs."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the workspace transformation DCR."
      }
    },
    "appObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID of the app managed identity to exclude from StorageBlobLogs."
      }
    },
    "namePrefix": {
      "type": "string",
      "metadata": {
        "description": "Prefix used for uniquely named DCR resources in this environment."
      }
    }
  },
  "variables": {
    "workspaceName": "[last(split(parameters('workspaceResourceId'), '/'))]",
    "transformDcrName": "[format('{0}-storageblob-logs-transform-dcr', parameters('namePrefix'))]",
    "dcrAssociationName": "[format('{0}-storageblob-logs-transform-assoc', parameters('namePrefix'))]",
    "logAnalyticsDestinationName": "audit-logs",
    "blobLogsTransformKql": "[format('source | where RequesterObjectId != \"{0}\"', parameters('appObjectId'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[variables('transformDcrName')]",
      "location": "[parameters('location')]",
      "kind": "WorkspaceTransforms",
      "properties": {
        "dataSources": {},
        "dataFlows": [
          {
            "streams": [
              "Microsoft-Table-StorageBlobLogs"
            ],
            "destinations": [
              "[variables('logAnalyticsDestinationName')]"
            ],
            "transformKql": "[variables('blobLogsTransformKql')]"
          }
        ],
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "[variables('logAnalyticsDestinationName')]"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Insights/dataCollectionRuleAssociations",
      "apiVersion": "2023-03-11",
      "scope": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]",
      "name": "[variables('dcrAssociationName')]",
      "properties": {
        "dataCollectionRuleId": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('transformDcrName'))]",
        "description": "Exclude app managed identity from StorageBlobLogs in the audit workspace"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/dataCollectionRules', variables('transformDcrName'))]"
      ]
    }
  ],
  "outputs": {
    "dataCollectionRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('transformDcrName'))]"
    }
  }
}